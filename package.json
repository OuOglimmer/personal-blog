{
  "name": "look-blog",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:ssr": "node server.js",
    "build": "vue-tsc -b && vite build",
    "build:ssr": "npm run build:ssr:client && npm run build:ssr:server",
    "build:ssr:client": "vite build --outDir dist/client",
    "build:ssr:server": "vite build --ssr src/entry-server.ts --outDir dist/server",
    "preview": "vite preview",
    "preview:ssr": "NODE_ENV=production node server.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.107.0",
    "@tailwindcss/vite": "^4.3.0",
    "element-plus": "^2.14.1",
    "less": "^4.6.4",
    "pinia": "^3.0.4",
    "router": "^2.2.0",
    "scss": "^0.2.4",
    "tailwindcss": "^4.3.0",
    "three": "^0.184.0",
    "vue": "^3.5.34",
    "vue-i18n": "^11.4.5",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "express": "^4.22.2",
    "sass-embedded": "^1.100.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vue-tsc": "^3.2.8"
  }
}
